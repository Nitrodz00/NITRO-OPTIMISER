<UserControl x:Class="NitroOptimizer.Views.DriversView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{StaticResource TextWhiteBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="SYSTEM DRIVERS" FontSize="24" FontWeight="Bold" Foreground="{StaticResource CyanBrush}" Margin="0,0,0,20"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding InstalledDrivers}" AutoGenerateColumns="False" 
                  IsReadOnly="True" Background="#11111A" Foreground="White" RowBackground="#161622" AlternatingRowBackground="#11111A"
                  HeadersVisibility="Column" BorderBrush="{StaticResource MagentaBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Device Name" Binding="{Binding Name}" Width="300"/>
                <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="200"/>
                <DataGridTextColumn Header="Driver Version" Binding="{Binding Version}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Refresh List" Style="{StaticResource NeonButtonStyle}" Command="{Binding LoadDriversCommand}" Width="120"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
