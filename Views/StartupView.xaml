<UserControl x:Class="NitroOptimizer.Views.StartupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{StaticResource TextWhiteBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="STARTUP PROGRAMS" FontSize="24" FontWeight="Bold" Foreground="{StaticResource CyanBrush}" Margin="0,0,0,20"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding StartupItems}" SelectedItem="{Binding SelectedItem}" AutoGenerateColumns="False" 
                  IsReadOnly="True" Background="#11111A" Foreground="White" RowBackground="#161622" AlternatingRowBackground="#11111A"
                  HeadersVisibility="Column" BorderBrush="{StaticResource MagentaBrush}" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="60"/>
                <DataGridTextColumn Header="Application Name" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Refresh" Style="{StaticResource NeonButtonStyle}" Command="{Binding LoadStartupItemsCommand}" Width="100" Margin="0,0,10,0"/>
            <Button Content="Enable / Disable" Style="{StaticResource NeonButtonStyle}" Command="{Binding ToggleStateCommand}" BorderBrush="{StaticResource MagentaBrush}" Width="150"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
