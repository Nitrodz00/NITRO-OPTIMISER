<UserControl x:Class="NitroOptimizer.Views.ProcessesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{StaticResource TextWhiteBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="RUNNING PROCESSES" FontSize="24" FontWeight="Bold" Foreground="{StaticResource MagentaBrush}" Margin="0,0,0,20"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding RunningProcesses}" SelectedItem="{Binding SelectedProcess}" AutoGenerateColumns="False" 
                  IsReadOnly="True" Background="#11111A" Foreground="White" RowBackground="#161622" AlternatingRowBackground="#11111A"
                  HeadersVisibility="Column" BorderBrush="{StaticResource CyanBrush}" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Process Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Memory Usage" Binding="{Binding Memory}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Refresh" Style="{StaticResource NeonButtonStyle}" Command="{Binding LoadProcessesCommand}" Width="100" Margin="0,0,10,0"/>
            <Button Content="End Task" Style="{StaticResource NeonButtonStyle}" Command="{Binding KillProcessCommand}" BorderBrush="Red" Width="100"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="Gray" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
