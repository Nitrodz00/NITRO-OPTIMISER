<Window x:Class="NitroOptimizer.Views.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nitro Stats Widget" Height="150" Width="180"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="Manual"
        Left="20" Top="20" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#CC0C0C18" CornerRadius="8" BorderBrush="#88FF00FF" BorderThickness="1.5" Padding="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Color="Magenta" Opacity="0.4" ShadowDepth="0"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,5">
                <TextBlock Text="NITRO STATS" Foreground="#22D3EE" FontSize="11" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <Button Content="x" Foreground="Red" Background="Transparent" BorderThickness="0" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" Click="Close_Click" Padding="0" Margin="0,-2,0,0" Width="15" Height="15"/>
            </Grid>

            <!-- Stats -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <!-- CPU -->
                <Grid Margin="0,2">
                    <TextBlock Text="CPU:" Foreground="LightGray" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding CpuUsage}" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
                <!-- GPU -->
                <Grid Margin="0,2">
                    <TextBlock Text="GPU:" Foreground="LightGray" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding GpuUsage}" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
                <!-- RAM -->
                <Grid Margin="0,2">
                    <TextBlock Text="RAM:" Foreground="LightGray" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding RamUsage}" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
                <!-- NET -->
                <Grid Margin="0,2">
                    <TextBlock Text="NET:" Foreground="LightGray" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding NetSpeed}" Foreground="#F43F5E" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
