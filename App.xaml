<Application x:Class="NitroOptimizer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="Application_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="BgDark">#0B0B0F</Color>
            <Color x:Key="BgLighter">#161622</Color>
            <Color x:Key="MagentaAccent">#FF00FF</Color>
            <Color x:Key="CyanAccent">#00FFFF</Color>
            <Color x:Key="TextWhite">#FFFFFF</Color>

            <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
            <SolidColorBrush x:Key="BgLighterBrush" Color="{StaticResource BgLighter}"/>
            <SolidColorBrush x:Key="MagentaBrush" Color="{StaticResource MagentaAccent}"/>
            <SolidColorBrush x:Key="CyanBrush" Color="{StaticResource CyanAccent}"/>
            <SolidColorBrush x:Key="TextWhiteBrush" Color="{StaticResource TextWhite}"/>

            <Style TargetType="Button" x:Key="NeonButtonStyle">
                <Setter Property="Background" Value="{StaticResource BgLighterBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextWhiteBrush}"/>
                <Setter Property="Padding" Value="15,5"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{StaticResource MagentaBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#222233"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
